config {
  type: "table",
  name: "deal_jackets",
  description: "Synthetic F&I contract details for customers' vehicle purchases",
  columns: {
    deal_id: "Unique finance deal identifier",
    customer_id: "Reference to the borrower customer_id",
    vin: "Reference to the financed vehicle's vin",
    finance_provider: "Assigned finance institution",
    credit_score: "Synthetically assigned credit score (580 to 830)",
    loan_amount: "Synthetically assigned loan amount ($28,000 to $48,000)",
    interest_rate: "Weighted interest rate based on credit score",
    status: "Contract lifecycle status (APPROVED, IN_AUDIT, COMPLETED)"
  }
}

WITH base_deals AS (
  SELECT
    vin,
    customer_id,
    ROW_NUMBER() OVER(ORDER BY vin) AS row_num,
    -- Determine deterministic pseudo-random values using FARM_FINGERPRINT
    580 + ABS(MOD(FARM_FINGERPRINT(vin), 250)) AS credit_score,
    28000 + ABS(MOD(FARM_FINGERPRINT(vin || 'loan'), 20000)) AS loan_amount,
    ABS(MOD(FARM_FINGERPRINT(vin || 'provider'), 4)) AS provider_hash,
    ABS(MOD(FARM_FINGERPRINT(vin || 'status'), 100)) AS status_hash
  FROM ${ref("vehicles")}
)
SELECT
  FORMAT('D%03d', row_num) AS deal_id,
  customer_id,
  vin,
  CASE provider_hash
    WHEN 0 THEN 'Toyota Financial Services'
    WHEN 1 THEN 'Penske Finance'
    WHEN 2 THEN 'Chase Auto'
    ELSE 'Bank of America'
  END AS finance_provider,
  credit_score,
  CAST(loan_amount AS FLOAT64) AS loan_amount,
  -- Assign interest rate weighted by credit score
  CASE 
    WHEN credit_score >= 740 THEN ROUND(3.4 + ABS(MOD(FARM_FINGERPRINT(vin || 'rate'), 150)) / 100.0, 2)
    WHEN credit_score >= 670 THEN ROUND(5.0 + ABS(MOD(FARM_FINGERPRINT(vin || 'rate'), 190)) / 100.0, 2)
    ELSE ROUND(7.0 + ABS(MOD(FARM_FINGERPRINT(vin || 'rate'), 290)) / 100.0, 2)
  END AS interest_rate,
  CASE 
    WHEN status_hash < 20 THEN 'APPROVED'
    WHEN status_hash < 35 THEN 'IN_AUDIT'
    ELSE 'COMPLETED'
  END AS status
FROM base_deals
